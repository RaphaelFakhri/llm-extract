# All variables are OPTIONAL. With none set, the pipeline runs fully offline
# using the deterministic MockLLMClient and the JSON delivery sink.

# --- OpenRouter (real LLM) ---
# When OPENROUTER_API_KEY is present, the real OpenRouter client is used.
# Leave unset to use the deterministic mock client (default for tests/dev).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Google Sheets delivery ---
# When BOTH of these are present, validated records are written to Sheets.
# Otherwise delivery falls back to deterministic JSON on disk.
# GOOGLE_SERVICE_ACCOUNT_JSON may be a path to a file or an inline JSON blob.
GOOGLE_SERVICE_ACCOUNT_JSON=
GSHEET_ID=

# --- Live source (optional, default off) ---
# Set LIVE_SOURCE_ENABLED=true only for an explicitly sanctioned source.
LIVE_SOURCE_ENABLED=false
LIVE_SOURCE_URL=https://example.com/sanctioned-listing
